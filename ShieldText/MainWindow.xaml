<Window x:Class="ShieldText.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ShieldText.ViewModels"
        Title="ShieldText" Height="680" Width="860"
        MinHeight="600" MinWidth="750"
        WindowStartupLocation="CenterScreen"
        Background="#0F1117">

    <Window.Resources>
        <!-- ── Colors ── -->
        <SolidColorBrush x:Key="BgMain"       Color="#0F1117"/>
        <SolidColorBrush x:Key="BgCard"       Color="#1A1D27"/>
        <SolidColorBrush x:Key="BgInput"      Color="#13151E"/>
        <SolidColorBrush x:Key="AccentBlue"   Color="#4F8EF7"/>
        <SolidColorBrush x:Key="AccentGreen"  Color="#3DDC97"/>
        <SolidColorBrush x:Key="TextPrimary"  Color="#F0F2FF"/>
        <SolidColorBrush x:Key="TextMuted"    Color="#6B7280"/>
        <SolidColorBrush x:Key="Border"       Color="#2A2D3A"/>

        <!-- ── TextBox Style ── -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background"   Value="{StaticResource BgInput}"/>
            <Setter Property="Foreground"   Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"  Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="12,10"/>
            <Setter Property="FontFamily"   Value="Consolas"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="CaretBrush"   Value="{StaticResource AccentBlue}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── PasswordBox Style ── -->
        <Style x:Key="ModernPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background"   Value="{StaticResource BgInput}"/>
            <Setter Property="Foreground"   Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"  Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="12,10"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Primary Button Style ── -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"        Value="{StaticResource AccentBlue}"/>
            <Setter Property="Foreground"        Value="White"/>
            <Setter Property="BorderThickness"   Value="0"/>
            <Setter Property="FontSize"          Value="14"/>
            <Setter Property="FontWeight"        Value="SemiBold"/>
            <Setter Property="Cursor"            Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="0,12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Ghost Button Style ── -->
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource TextMuted}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="{StaticResource Border}"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="10,6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1A1D27"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="🛡 ShieldText"
                       FontSize="26" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimary}"/>
            <TextBlock Text="Secure text encryption with AES-256"
                       FontSize="13"
                       Foreground="{StaticResource TextMuted}"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- ── Password Row ── -->
        <Border Grid.Row="1"
                Background="{StaticResource BgCard}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="1" CornerRadius="10"
                Padding="16,14" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="🔑  Password"
                           Foreground="{StaticResource TextMuted}"
                           FontSize="13" VerticalAlignment="Center"
                           Margin="0,0,14,0"/>

                <Grid Grid.Column="1">
                    <PasswordBox x:Name="PasswordBox"
                                 Style="{StaticResource ModernPasswordBox}"
                                 PasswordChanged="PasswordBox_PasswordChanged"/>
                                    <TextBox x:Name="PasswordVisible"
                                               Style="{StaticResource ModernTextBox}"
                                               Visibility="Collapsed"
                                               TextChanged="PasswordVisible_TextChanged"/>
                </Grid>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="ShowPasswordBtn"
                              Content="👁 Show"
                              Style="{StaticResource GhostButton}"
                              Margin="12,0,8,0"
                              Click="ShowPassword_Click"/>
                    <Button Content="Clear All"
                            Style="{StaticResource GhostButton}"
                            Click="ClearAll_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Input ── -->
        <Border Grid.Row="2"
                Background="{StaticResource BgCard}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="1" CornerRadius="10"
                Padding="16" Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="INPUT"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource TextMuted}"
                           Margin="0,0,0,10"/>

                <TextBox Grid.Row="1"
                         Style="{StaticResource ModernTextBox}"
                         Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         MinHeight="120"/>
            </Grid>
        </Border>

        <!-- ── Action Buttons ── -->
        <Grid Grid.Row="3" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="🔒  Encrypt"
                    Style="{StaticResource PrimaryButton}"
                    Click="Encrypt_Click"/>

            <Button Grid.Column="2" Content="🔓  Decrypt"
                    Style="{StaticResource PrimaryButton}"
                    Background="{StaticResource AccentGreen}"
                    Foreground="#0F1117"
                    Click="Decrypt_Click"/>

            <Button Grid.Column="4" Content="⇅  Swap"
                    Style="{StaticResource GhostButton}"
                    Padding="16,12"
                    Click="Swap_Click"/>
        </Grid>

        <!-- ── Output ── -->
        <Border Grid.Row="4"
                Background="{StaticResource BgCard}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="1" CornerRadius="10"
                Padding="16" Margin="0,0,0,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock Text="OUTPUT"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMuted}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="📋  Copy"
                                Style="{StaticResource GhostButton}"
                                Margin="0,0,8,0"
                                Click="Copy_Click"/>
                        <Button Content="💾  Save"
                                Style="{StaticResource GhostButton}"
                                Click="Save_Click"/>
                    </StackPanel>
                </Grid>

                <TextBox Grid.Row="1"
                         Style="{StaticResource ModernTextBox}"
                         Text="{Binding OutputText, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         IsReadOnly="True"
                         MinHeight="120"/>
            </Grid>
        </Border>

        <!-- ── Status Bar ── -->
        <!-- ── Status Bar ── -->
        <Border Grid.Row="5"
                Background="{StaticResource BgCard}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="1" CornerRadius="8"
                Padding="14,10">
            <Grid>
                <TextBlock x:Name="StatusText"
                             Text="{Binding StatusMessage}"
                             FontSize="13"
                             Foreground="{StaticResource TextMuted}"
                             HorizontalAlignment="Left"/>
                <TextBlock Text="Powered by Nader Asadpour"
                           FontSize="11"
                           Foreground="{StaticResource TextMuted}"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           Opacity="0.5"/>
            </Grid>
        </Border>
    </Grid>
</Window>